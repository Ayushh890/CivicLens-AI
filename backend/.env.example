# MongoDB Atlas - Get from https://cloud.mongodb.com (free tier)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/civiclens?retryWrites=true&w=majority

# Cloudinary - Get from https://cloudinary.com/console (free tier)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT Secret - Change this to any random string
JWT_SECRET=civiclens_jwt_secret_change_me_2026
